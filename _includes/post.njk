<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ title }} | Elliot Clowes</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="mx-auto max-w-screen-lg py-4 min-h-screen bg-[#f8f8f8] text-xl max-sm:text-lg">
<nav class="text-neutral-400 flex mb-12 max-sm:hidden justify-center">
  <a class='text-black' href="/">clowes.blog</a>
  <a class href='/about'>about</a>
</nav>
<article class="flex flex-col gap-8 grow">
  <div class="mastodon-card" id="mastodon-card">
    <div class="mastodon-header">
        <img src="/static/elliot-clowes.jpg" alt="User Avatar" class="mastodon-avatar">
        <div class="mastodon-user">
            <div class="mastodon-display-name"><a href="https://mastodon.cloud/@clowes">Elliot Clowes</a></div>
            <div class="mastodon-username"><a href="https://mastodon.cloud/@clowes">clowes.blog</a></div>
        </div>
    </div>
    <div class="mastodon-content">
      {{ content | safe }}
    </div>
    <div class="mastodon-footer">{{ date | customDate }}</div>
  </div>
  </article>
<footer class="mt-24 flex justify-center">
  <div></div>
</footer>
<script src="/js/scripts.js"></script>
</body>
</html>
