<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="mx-auto max-w-screen-lg py-4 min-h-screen bg-[#f8f8f8] text-xl max-sm:text-lg">
<nav class="text-neutral-400 flex mb-12 max-sm:hidden">
<a class="" href="/">home</a>
<a class href='/about-us'>about us</a>
<a class='text-black' href='/changelog'>changelog</a>
<a class href='/buy'>pricing</a>
</nav>
<article class="flex flex-col gap-8 grow">
  <div class="mastodon-card" id="mastodon-card">
    <div class="mastodon-header">
        <img src="/assets/static/elliot-clowes.jpg" alt="User Avatar" class="mastodon-avatar">
        <div class="mastodon-user">
            <div class="mastodon-display-name"><a href="https://mastodon.cloud/@clowes">Elliot Clowes</a></div>
            <div class="mastodon-username"><a href="https://mastodon.cloud/@clowes">@clowes</a></div>
        </div>
    </div>
    <div class="mastodon-content">
      {{ content | safe }}
    </div>
    <div class="mastodon-footer"><a href="#">{{ date | customDate }}</a></div>
  </div>
  </article>
<footer class="mt-24">
Follow <a href="https://twitter.com/nota_md">@nota_md</a> for updates.
</footer>
<script src="/js/scripts.js"></script>
</body>
</html>

